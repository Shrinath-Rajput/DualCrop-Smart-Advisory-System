                    <div class="col-md-4">
                        <div class="card h-100 shadow-sm border-0 feature-card">
                            <div class="card-body text-center">
                                <i
                                    class="fas fa-brain text-danger"
                                    style="font-size: 3rem"
                                ></i>
                                <h5 class="card-title mt-3">ML-Powered</h5>
                                <p class="card-text">
                                    Powered by state-of-the-art deep learning models trained on thousands
