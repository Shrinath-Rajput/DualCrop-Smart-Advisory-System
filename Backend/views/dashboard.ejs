<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard | DualCrop Smart Advisory System</title>
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
        rel="stylesheet"
    />
    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="d-flex flex-column min-vh-100">
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/">
                <i class="fas fa-leaf"></i> DualCrop Advisory
            </a>
            <button
                class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarNav"
            >
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/"><i class="fas fa-home"></i> Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/analyze"
                            ><i class="fas fa-microscope"></i> Analyze</a
                        >
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/weather"
                            ><i class="fas fa-cloud-sun"></i> Weather</a
                        >
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/dashboard"
                            ><i class="fas fa-chart-bar"></i> Dashboard</a
                        >
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/chatbot"
                            ><i class="fas fa-comments"></i> Chatbot</a
                        >
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/about"
                            ><i class="fas fa-info-circle"></i> About</a
                        >
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <main class="flex-grow-1 py-5">
        <div class="container">
            <h1 class="mb-4 fw-bold">
                <i class="fas fa-chart-bar text-primary"></i> Dashboard
            </h1>

            <!-- STATS SECTION -->
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="card text-center shadow-sm border-0">
                        <div class="card-body">
                            <i class="fas fa-file-upload text-primary" style="font-size: 2rem"></i>
                            <h3 class="mt-3"><%= count %></h3>
                            <p class="text-muted">Total Analyses</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center shadow-sm border-0">
                        <div class="card-body">
                            <i
                                class="fas fa-check-circle text-success"
                                style="font-size: 2rem"
                            ></i>
                            <h3 class="mt-3" id="healthyCount">0</h3>
                            <p class="text-muted">Healthy Crops</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center shadow-sm border-0">
                        <div class="card-body">
                            <i class="fas fa-exclamation-circle text-warning" style="font-size: 2rem"></i>
                            <h3 class="mt-3" id="diseaseCount">0</h3>
                            <p class="text-muted">Diseases Detected</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center shadow-sm border-0">
                        <div class="card-body">
                            <i
                                class="fas fa-percentage text-info"
                                style="font-size: 2rem"
                            ></i>
                            <h3 class="mt-3" id="avgConfidence">0%</h3>
                            <p class="text-muted">Avg. Confidence</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ERROR MESSAGE -->
            <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-triangle"></i>
                <%= error %>
                <button
                    type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Close"
                ></button>
            </div>
            <% } %>

            <!-- PREDICTIONS TABLE -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="fas fa-table"></i> Recent Predictions
                    </h5>
                </div>
                <div class="card-body">
                    <% if (predictions && predictions.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>
                                        <i class="fas fa-image"></i> Image
                                    </th>
                                    <th>
                                        <i class="fas fa-stethoscope"></i> Prediction
                                    </th>
                                    <th>
                                        <i class="fas fa-percentage"></i> Confidence
                                    </th>
                                    <th>
                                        <i class="fas fa-calendar"></i> Date
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <% predictions.forEach((pred) => { %>
                                <tr>
                                    <td>
                                        <img
                                            src="/uploads/<%= pred.image %>"
                                            alt="<%= pred.result %>"
                                            style="max-width: 50px; border-radius: 5px"
                                        />
                                    </td>
                                    <td class="fw-bold"><%= pred.result %></td>
                                    <td>
                                        <div class="progress" style="width: 150px; height: 20px">
                                            <div
                                                class="progress-bar bg-success"
                                                role="progressbar"
                                                style="width: <%= pred.confidence %>%"
                                                aria-valuenow="<%= pred.confidence %>"
                                                aria-valuemin="0"
                                                aria-valuemax="100"
                                            >
                                                <%= Math.round(pred.confidence) %>%
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            <%= new Date(pred.created_at).toLocaleDateString() %>
                                            <br />
                                            <%= new Date(pred.created_at).toLocaleTimeString() %>
                                        </small>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                    <div class="alert alert-info" role="alert">
                        <i class="fas fa-info-circle"></i> No predictions yet. Start by
                        <a href="/analyze" class="alert-link">analyzing an image</a>.
                    </div>
                    <% } %>
                </div>
            </div>

            <!-- ACTION BUTTONS -->
            <div class="mt-4 d-flex gap-2">
                <a href="/analyze" class="btn btn-primary">
                    <i class="fas fa-plus"></i> New Analysis
                </a>
                <button class="btn btn-outline-secondary" onclick="location.reload()">
                    <i class="fas fa-redo"></i> Refresh
                </button>
            </div>
        </div>
    </main>

    <!-- FOOTER -->
    <footer class="bg-dark text-white text-center py-4 mt-5 shadow">
        <div class="container">
            <p class="mb-2">
                <strong>DualCrop Smart Advisory System</strong> - AI-Based Crop Disease
                Detection
            </p>
            <p class="mb-0">
                <small>
                    Built with <i class="fas fa-heart text-danger"></i> using Node.js, Python
                    Flask, and Machine Learning
                </small>
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Calculate statistics
        document.addEventListener("DOMContentLoaded", function () {
            const predictions = <%- JSON.stringify(predictions) %>;
            
            if (predictions && predictions.length > 0) {
                let healthyCount = 0;
                let diseaseCount = 0;
                let totalConfidence = 0;

                predictions.forEach((pred) => {
                    if (pred.result.toLowerCase().includes("healthy")) {
                        healthyCount++;
                    } else {
                        diseaseCount++;
                    }
                    totalConfidence += pred.confidence;
                });

                document.getElementById("healthyCount").textContent = healthyCount;
                document.getElementById("diseaseCount").textContent = diseaseCount;
                const avgConfidence = Math.round(totalConfidence / predictions.length);
                document.getElementById("avgConfidence").textContent = avgConfidence + "%";
            }
        });
    </script>
</body>
</html>