<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard | DualCrop Smart Advisory System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="d-flex flex-column min-vh-100">
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/"><i class="fas fa-leaf"></i> DualCrop</a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/"><i class="fas fa-home"></i> Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/analyze"><i class="fas fa-microscope"></i> Analyze</a></li>
                    <li class="nav-item"><a class="nav-link" href="/weather"><i class="fas fa-cloud-sun"></i> Weather</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/dashboard"><i class="fas fa-chart-bar"></i> Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="/chatbot"><i class="fas fa-comments"></i> Chatbot</a></li>
                    <li class="nav-item"><a class="nav-link" href="/about"><i class="fas fa-info-circle"></i> About</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="languageDropdown" role="button" data-bs-toggle="dropdown">
                            <i class="fas fa-globe"></i> Language
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="languageDropdown">
                            <li><a class="dropdown-item" href="#" onclick="changeLanguage('en'); return false;">🇬🇧 English</a></li>
                            <li><a class="dropdown-item" href="#" onclick="changeLanguage('hi'); return false;">🇮🇳 हिंदी</a></li>
                            <li><a class="dropdown-item" href="#" onclick="changeLanguage('mr'); return false;">🇮🇳 मराठी</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <main class="flex-grow-1 section-padding">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center mb-5">
                <div>
                    <h1 class="gradient-text mb-2">📊 Analytics Dashboard</h1>
                    <p class="text-secondary">Your prediction history and statistics</p>
                </div>
                <a href="/analyze" class="btn btn-primary">
                    <i class="fas fa-plus"></i> New Analysis
                </a>
            </div>

            <!-- STATS SECTION -->
            <div class="dashboard-grid">
                <div class="stat-card">
                    <div class="stat-card-icon" style="background: linear-gradient(135deg, rgba(16, 185, 129, 0.2) 0%, rgba(6, 182, 212, 0.2) 100%);">
                        <i class="fas fa-file-upload" style="color: var(--accent-green);"></i>
                    </div>
                    <div class="stat-card-value"><%= count %></div>
                    <div class="stat-card-label">Total Analyses</div>
                </div>

                <div class="stat-card">
                    <div class="stat-card-icon" style="background: linear-gradient(135deg, rgba(16, 185, 129, 0.2) 0%, rgba(6, 182, 212, 0.2) 100%);">
                        <i class="fas fa-check-circle" style="color: var(--accent-green);"></i>
                    </div>
                    <div class="stat-card-value" id="healthyCount">0</div>
                    <div class="stat-card-label">Healthy Crops</div>
                </div>

                <div class="stat-card">
                    <div class="stat-card-icon" style="background: linear-gradient(135deg, rgba(239, 68, 68, 0.2) 0%, rgba(168, 85, 247, 0.2) 100%);">
                        <i class="fas fa-exclamation-circle" style="color: #dc2626;"></i>
                    </div>
                    <div class="stat-card-value" id="diseaseCount">0</div>
                    <div class="stat-card-label">Diseases Detected</div>
                </div>

                <div class="stat-card">
                    <div class="stat-card-icon" style="background: linear-gradient(135deg, rgba(168, 85, 247, 0.2) 0%, rgba(6, 182, 212, 0.2) 100%);">
                        <i class="fas fa-percentage" style="color: var(--accent-purple);"></i>
                    </div>
                    <div class="stat-card-value" id="avgConfidence">0%</div>
                    <div class="stat-card-label">Avg. Confidence</div>
                </div>
            </div>

            <!-- ERROR MESSAGE -->
            <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger alert-dismissible fade show d-flex align-items-start" role="alert">
                <i class="fas fa-exclamation-triangle me-3 mt-1" style="font-size: 1.25rem;"></i>
                <div>
                    <strong>Error</strong>
                    <p class="mb-0"><%= error %></p>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% } %>

            <!-- PREDICTIONS TABLE -->
            <div class="card mt-4">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="fas fa-history"></i> Recent Predictions</h5>
                        <small class="text-secondary">Latest analyses</small>
                    </div>
                </div>
                <div class="card-body">
                    <% if (predictions && predictions.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th><i class="fas fa-image"></i> Image</th>
                                    <th><i class="fas fa-leaf"></i> Prediction</th>
                                    <th><i class="fas fa-percentage"></i> Confidence</th>
                                    <th><i class="fas fa-calendar"></i> Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% predictions.forEach(prediction => { %>
                                <tr>
                                    <td>
                                        <img src="/uploads/<%= prediction.image %>" alt="Thumbnail" style="width: 50px; height: 50px; border-radius: 0.5rem; object-fit: cover;" />
                                    </td>
                                    <td>
                                        <span class="badge" style="<% if (prediction.prediction.toLowerCase().includes('healthy')) { %>background: linear-gradient(135deg, var(--accent-green) 0%, #06b6d4 100%);<% } else { %>background: linear-gradient(135deg, #ef4444 0%, var(--accent-purple) 100%);<% } %> color: white;">
                                            <%= prediction.prediction %>
                                        </span>
                                    </td>
                                    <td>
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar" role="progressbar" style="width: <%= prediction.confidence %>%; background: linear-gradient(135deg, var(--accent-green) 0%, var(--accent-cyan) 100%);"></div>
                                        </div>
                                        <small class="text-secondary"><%= Math.round(prediction.confidence) %>%</small>
                                    </td>
                                    <td>
                                        <small class="text-secondary"><%= new Date(prediction.created_at).toLocaleDateString() %></small>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                    <div class="text-center py-5">
                        <i class="fas fa-inbox" style="font-size: 3rem; color: var(--text-secondary); opacity: 0.5;"></i>
                        <p class="mt-3 text-secondary">No predictions yet. <a href="/analyze">Start your first analysis</a></p>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    </main>

    <!-- FOOTER -->
    <footer>
        <div class="container">
            <div class="row g-4 mb-4">
                <div class="col-md-3">
                    <h5><i class="fas fa-leaf" style="color: var(--accent-green);"></i> DualCrop</h5>
                    <p class="small text-muted">AI-powered crop disease detection for modern farmers.</p>
                </div>
                <div class="col-md-3">
                    <h5>Quick Links</h5>
                    <ul class="list-unstyled small">
                        <li><a href="/">Home</a></li>
                        <li><a href="/analyze">Analyze</a></li>
                        <li><a href="/weather">Weather</a></li>
                        <li><a href="/about">About</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h5>Features</h5>
                    <ul class="list-unstyled small">
                        <li><a href="/analyze">Disease Detection</a></li>
                        <li><a href="/weather">Weather Advisory</a></li>
                        <li><a href="/chatbot">AI Chatbot</a></li>
                        <li><a href="/dashboard">Analytics</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h5>Follow</h5>
                    <div class="social-links">
                        <a href="#" title="Facebook"><i class="fab fa-facebook"></i></a>
                        <a href="#" title="Twitter"><i class="fab fa-twitter"></i></a>
                        <a href="#" title="LinkedIn"><i class="fab fa-linkedin"></i></a>
                        <a href="#" title="GitHub"><i class="fab fa-github"></i></a>
                    </div>
                </div>
            </div>
            <div class="footer-divider"></div>
            <div class="text-center">
                <p class="footer-text mb-0">
                    <strong>DualCrop Smart Advisory System</strong> © 2024. All rights reserved. | Built with <i class="fas fa-heart" style="color: #ec4899;"></i> for Modern Agriculture
                </p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/language-manager.js"></script>
    <script src="/js/main.js"></script>
    <script>
        // Calculate statistics
        function updateStatistics() {
            const rows = document.querySelectorAll('table tbody tr');
            let healthy = 0, disease = 0, totalConfidence = 0;

            rows.forEach(row => {
                const cells = row.querySelectorAll('td');
                if (cells.length >= 3) {
                    const prediction = cells[1].textContent.toLowerCase();
                    const confidenceText = cells[2].querySelector('small') || cells[2];
                    const confidence = parseFloat(confidenceText.textContent) || 0;
                    
                    if (prediction.includes('healthy')) {
                        healthy++;
                    } else {
                        disease++;
                    }
                    totalConfidence += confidence;
                }
            });

            document.getElementById('healthyCount').textContent = healthy;
            document.getElementById('diseaseCount').textContent = disease;
            const avgConfidence = rows.length > 0 ? Math.round(totalConfidence / rows.length) : 0;
            document.getElementById('avgConfidence').textContent = avgConfidence + '%';
        }

        updateStatistics();

        function changeLanguage(lang) {
            if (languageManager) {
                languageManager.setLanguage(lang);
                languageManager.applyTranslations();
            }
        }
    </script>
</body>
</html>
