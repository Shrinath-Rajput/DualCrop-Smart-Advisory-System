<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Weather & Crop Advisory | DualCrop Smart Advisory System</title>
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
        rel="stylesheet"
    />
    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="d-flex flex-column min-vh-100">
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/">
                <i class="fas fa-leaf"></i> DualCrop Advisory
            </a>
            <button
                class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarNav"
            >
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/"><i class="fas fa-home"></i> Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/analyze"
                            ><i class="fas fa-microscope"></i> Analyze</a
                        >
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/weather"
                            ><i class="fas fa-cloud-sun"></i> Weather</a
                        >
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard"
                            ><i class="fas fa-chart-bar"></i> Dashboard</a
                        >
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/chatbot"
                            ><i class="fas fa-comments"></i> Chatbot</a
                        >
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/about"
                            ><i class="fas fa-info-circle"></i> About</a
                        >
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <main class="flex-grow-1 py-5">
        <div class="container">
            <h1 class="mb-4 fw-bold">
                <i class="fas fa-cloud-sun text-info"></i> Weather & Crop Advisory
            </h1>
            <p class="text-muted mb-4">
                Get real-time weather data and personalized crop recommendations based on climate conditions.
            </p>

            <div class="row g-4">
                <!-- INPUT SECTION -->
                <div class="col-md-6">
                    <div class="card shadow-sm border-0">
                        <div class="card-body">
                            <h5 class="card-title mb-4">
                                <i class="fas fa-map-marker-alt"></i> Search City
                            </h5>

                            <form id="weatherForm">
                                <div class="mb-3">
                                    <label for="cityInput" class="form-label">Enter City Name</label>
                                    <input
                                        type="text"
                                        class="form-control form-control-lg"
                                        id="cityInput"
                                        name="city"
                                        placeholder="e.g., Delhi, Mumbai, Bangalore"
                                        required
                                    />
                                </div>

                                <button type="submit" class="btn btn-info btn-lg w-100">
                                    <i class="fas fa-search"></i> Get Weather
                                </button>
                            </form>

                            <!-- Loading Spinner -->
                            <div id="loadingSpinner" style="display: none" class="text-center mt-4">
                                <div class="spinner-border text-info" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <p class="mt-2 text-muted">Fetching weather data...</p>
                            </div>

                            <!-- Error Message -->
                            <div id="errorAlert" class="alert alert-danger mt-4" style="display: none" role="alert">
                                <h6 class="alert-heading">
                                    <i class="fas fa-exclamation-circle"></i> Error
                                </h6>
                                <p id="errorMessage" class="mb-0"></p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- RESULT SECTION -->
                <div class="col-md-6">
                    <div id="resultCard" class="card shadow-sm border-0" style="display: none">
                        <div class="card-body">
                            <h5 class="card-title mb-4">
                                <i class="fas fa-cloud text-info"></i> Weather Information
                            </h5>

                            <!-- Location -->
                            <div class="mb-3">
                                <h4 id="cityName" class="fw-bold text-primary"></h4>
                                <p id="country" class="text-muted"></p>
                            </div>

                            <!-- Temperature Card -->
                            <div class="card bg-light mb-3">
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <p class="text-muted">Temperature</p>
                                            <h3 id="temperature" class="fw-bold text-danger"></h3>
                                        </div>
                                        <div class="col-md-6">
                                            <p class="text-muted">Feels Like</p>
                                            <h3 id="feelsLike" class="fw-bold text-warning"></h3>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Condition & Details -->
                            <div class="mb-3">
                                <p class="text-muted">Condition</p>
                                <h5 id="condition" class="fw-bold"></h5>
                                <p id="description" class="text-muted"></p>
                            </div>

                            <!-- Humidity & Wind -->
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <p class="text-muted">Humidity</p>
                                    <h4 id="humidity" class="fw-bold text-primary"></h4>
                                </div>
                                <div class="col-md-6">
                                    <p class="text-muted">Wind Speed</p>
                                    <h4 id="windSpeed" class="fw-bold text-success"></h4>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ADVISORY SECTION -->
            <div id="advisorySection" class="mt-5" style="display: none">
                <h3 class="fw-bold mb-4">
                    <i class="fas fa-lightbulb text-warning"></i> Crop Advisory
                </h3>

                <div id="advisoryBox" class="alert alert-warning" role="alert">
                    <ul id="advisoryList" class="mb-0"></ul>
                </div>

                <!-- CROP-SPECIFIC MEDICINE RECOMMENDATIONS -->
                <div class="row mt-4">
                    <!-- BRINJAL MEDICINE -->
                    <div class="col-md-6 mb-3">
                        <div class="card border-2 border-success" id="brinjalMedicineCard" style="display: none">
                            <div class="card-header bg-success text-white">
                                <h5 class="mb-0"><i class="fas fa-pills"></i> 🍆 Brinjal - Medicine Recommendation</h5>
                            </div>
                            <div class="card-body" id="brinjalMedicineContent"></div>
                        </div>
                    </div>

                    <!-- GRAPES MEDICINE -->
                    <div class="col-md-6 mb-3">
                        <div class="card border-2 border-danger" id="grapesMedicineCard" style="display: none">
                            <div class="card-header bg-danger text-white">
                                <h5 class="mb-0"><i class="fas fa-pills"></i> 🍇 Grapes - Medicine Recommendation</h5>
                            </div>
                            <div class="card-body" id="grapesMedicineContent"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- INFO SECTION -->
            <div class="row mt-5">
                <div class="col-md-12">
                    <div class="card bg-light border-0">
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="fas fa-info-circle"></i> Weather-Crop Advisory Tips
                            </h5>
                            <ul>
                                <li><strong>High Humidity (&gt;80%):</strong> Increase risk of fungal diseases - Apply fungicides</li>
                                <li><strong>Low Humidity (&lt;30%):</strong> Increase irrigation frequency to prevent drought stress</li>
                                <li><strong>Low Temperature (&lt;10°C):</strong> Protect crops from frost damage</li>
                                <li><strong>Strong Winds (&gt;15 km/h):</strong> Risk of physical damage - Monitor crops</li>
                                <li><strong>Rainy Season:</strong> Avoid pesticide/fertilizer application, increase drainage</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- FOOTER -->
    <footer class="bg-dark text-white text-center py-4 mt-5 shadow">
        <div class="container">
            <p class="mb-2">
                <strong>DualCrop Smart Advisory System</strong> - AI-Based Crop Disease Detection
            </p>
            <p class="mb-0">
                <small>
                    Built with <i class="fas fa-heart text-danger"></i> using Node.js, Python Flask, and Machine Learning
                </small>
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById("weatherForm").addEventListener("submit", async function (e) {
            e.preventDefault();

            const city = document.getElementById("cityInput").value;
            document.getElementById("loadingSpinner").style.display = "block";
            document.getElementById("resultCard").style.display = "none";
            document.getElementById("errorAlert").style.display = "none";
            document.getElementById("advisorySection").style.display = "none";

            try {
                const response = await fetch("/api/weather", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                    },
                    body: JSON.stringify({ city: city }),
                });

                const data = await response.json();

                if (data.success) {
                    // Display weather information
                    document.getElementById("cityName").textContent = data.city;
                    document.getElementById("country").textContent = "Country: " + data.country;
                    document.getElementById("temperature").textContent = data.temperature + "°C";
                    document.getElementById("feelsLike").textContent = data.feelsLike + "°C";
                    document.getElementById("condition").textContent = data.condition;
                    document.getElementById("description").textContent = data.description;
                    document.getElementById("humidity").textContent = data.humidity + "%";
                    document.getElementById("windSpeed").textContent = data.windSpeed + " km/h";

                    // Display advisory
                    const advisoryList = document.getElementById("advisoryList");
                    advisoryList.innerHTML = "";
                    data.advisory.forEach((item) => {
                        const li = document.createElement("li");
                        li.textContent = item;
                        advisoryList.appendChild(li);
                    });

                    // Display crop-specific medicines
                    if (data.cropMedicines) {
                        displayCropMedicines(data.cropMedicines);
                    }

                    document.getElementById("resultCard").style.display = "block";
                    document.getElementById("advisorySection").style.display = "block";
                } else {
                    showError(data.error || "Failed to fetch weather data");
                }
            } catch (error) {
                showError("Error: " + error.message);
            } finally {
                document.getElementById("loadingSpinner").style.display = "none";
            }
        });

        function displayCropMedicines(cropMedicines) {
            // Display Brinjal Medicine
            if (cropMedicines.Brinjal) {
                const brinjalContent = document.getElementById("brinjalMedicineContent");
                const medicine = cropMedicines.Brinjal;
                let html = "";
                
                if (medicine.description) {
                    html += `<p class="fw-bold text-success">${medicine.description}</p>`;
                }
                
                if (Array.isArray(medicine.medicine)) {
                    html += `<p><strong>💊 Medicines:</strong> ${medicine.medicine.join(", ")}</p>`;
                } else if (medicine.medicine) {
                    html += `<p><strong>💊 Medicine:</strong> ${medicine.medicine}</p>`;
                }
                
                if (medicine.dosage) {
                    html += `<p><strong>📏 Dosage:</strong> ${medicine.dosage}</p>`;
                }
                
                if (medicine.spraying_interval) {
                    html += `<p><strong>⏰ Interval:</strong> ${medicine.spraying_interval}</p>`;
                }
                
                if (medicine.preventive && Array.isArray(medicine.preventive)) {
                    html += `<p class="fw-bold mt-2">🛡️ Preventive Measures:</p><ul class="small">`;
                    medicine.preventive.forEach(item => {
                        html += `<li>${item}</li>`;
                    });
                    html += `</ul>`;
                }
                
                brinjalContent.innerHTML = html;
                document.getElementById("brinjalMedicineCard").style.display = "block";
            }

            // Display Grapes Medicine
            if (cropMedicines.Grapes) {
                const grapesContent = document.getElementById("grapesMedicineContent");
                const medicine = cropMedicines.Grapes;
                let html = "";
                
                if (medicine.description) {
                    html += `<p class="fw-bold text-danger">${medicine.description}</p>`;
                }
                
                if (Array.isArray(medicine.medicine)) {
                    html += `<p><strong>💊 Medicines:</strong> ${medicine.medicine.join(", ")}</p>`;
                } else if (medicine.medicine) {
                    html += `<p><strong>💊 Medicine:</strong> ${medicine.medicine}</p>`;
                }
                
                if (medicine.dosage) {
                    html += `<p><strong>📏 Dosage:</strong> ${medicine.dosage}</p>`;
                }
                
                if (medicine.spraying_interval) {
                    html += `<p><strong>⏰ Interval:</strong> ${medicine.spraying_interval}</p>`;
                }
                
                if (medicine.preventive && Array.isArray(medicine.preventive)) {
                    html += `<p class="fw-bold mt-2">🛡️ Preventive Measures:</p><ul class="small">`;
                    medicine.preventive.forEach(item => {
                        html += `<li>${item}</li>`;
                    });
                    html += `</ul>`;
                }
                
                grapesContent.innerHTML = html;
                document.getElementById("grapesMedicineCard").style.display = "block";
            }
        }

        function showError(message) {
            document.getElementById("errorMessage").textContent = message;
            document.getElementById("errorAlert").style.display = "block";
        }
    </script>
</body>
</html>