<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Weather & Crop Advisory | DualCrop Smart Advisory System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="d-flex flex-column min-vh-100">
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/"><i class="fas fa-leaf"></i> DualCrop</a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/"><i class="fas fa-home"></i> Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/analyze"><i class="fas fa-microscope"></i> Analyze</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/weather"><i class="fas fa-cloud-sun"></i> Weather</a></li>
                    <li class="nav-item"><a class="nav-link" href="/dashboard"><i class="fas fa-chart-bar"></i> Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="/chatbot"><i class="fas fa-comments"></i> Chatbot</a></li>
                    <li class="nav-item"><a class="nav-link" href="/about"><i class="fas fa-info-circle"></i> About</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="languageDropdown" role="button" data-bs-toggle="dropdown">
                            <i class="fas fa-globe"></i> Language
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="languageDropdown">
                            <li><a class="dropdown-item" href="#" onclick="changeLanguage('en'); return false;">🇬🇧 English</a></li>
                            <li><a class="dropdown-item" href="#" onclick="changeLanguage('hi'); return false;">🇮🇳 हिंदी</a></li>
                            <li><a class="dropdown-item" href="#" onclick="changeLanguage('mr'); return false;">🇮🇳 मराठी</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <main class="flex-grow-1 section-padding">
        <div class="container">
            <div class="text-center mb-5">
                <h1 class="gradient-text mb-3">🌤️ Weather & Crop Advisory</h1>
                <p class="text-secondary fs-5">Real-time weather data with personalized crop recommendations</p>
            </div>

            <div class="row g-4">
                <!-- SEARCH SECTION -->
                <div class="col-lg-6">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title mb-4">
                                <i class="fas fa-map-marker-alt"></i> Search City
                            </h5>

                            <form id="weatherForm">
                                <div class="mb-4">
                                    <label for="cityInput" class="form-label">Enter City Name</label>
                                    <input type="text" class="form-control form-control-lg" id="cityInput" name="city" placeholder="e.g., Delhi, Mumbai, Bangalore" required />
                                </div>

                                <button type="submit" class="btn btn-primary btn-lg w-100">
                                    <i class="fas fa-search"></i> Get Weather
                                </button>
                            </form>

                            <!-- Loading State -->
                            <div id="weatherLoading" style="display: none;" class="text-center mt-4">
                                <div class="spinner-border text-primary mb-3" role="status"></div>
                                <p class="text-secondary">Fetching weather data...</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- WEATHER RESULTS -->
                <div class="col-lg-6">
                    <!-- Weather Display -->
                    <div id="weatherDisplay" style="display: none;">
                        <!-- Current Weather -->
                        <div class="card mb-4">
                            <div class="card-body">
                                <h5 class="card-title mb-4" id="weatherCity"></h5>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div id="weatherTemp" style="font-size: 3rem; font-weight: bold; color: var(--accent-green);"></div>
                                        <p id="weatherDescription" class="text-secondary mb-0"></p>
                                    </div>
                                    <i id="weatherIcon" style="font-size: 4rem; color: var(--accent-cyan);"></i>
                                </div>
                            </div>
                        </div>

                        <!-- Weather Details -->
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <i class="fas fa-tint" style="font-size: 2rem; color: var(--accent-cyan);"></i>
                                        <p class="text-secondary small mt-2 mb-1">Humidity</p>
                                        <p id="humidity" class="fw-bold mb-0">0%</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <i class="fas fa-wind" style="font-size: 2rem; color: var(--accent-purple);"></i>
                                        <p class="text-secondary small mt-2 mb-1">Wind Speed</p>
                                        <p id="windSpeed" class="fw-bold mb-0">0 m/s</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Advisory -->
                        <div class="card" style="background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(6, 182, 212, 0.1) 100%);">
                            <div class="card-body">
                                <h6 class="card-title mb-3">
                                    <i class="fas fa-lightbulb" style="color: var(--accent-green);"></i> Crop Advisory
                                </h6>
                                <p id="weatherAdvisory" class="mb-0 small"></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- MEDICINE RECOMMENDATIONS -->
            <div class="row mt-4" id="medicineSection" style="display: none;">
                <div class="col-md-12">
                    <div class="card" style="background: linear-gradient(135deg, rgba(16, 185, 129, 0.05) 0%, rgba(239, 68, 68, 0.05) 100%);">
                        <div class="card-header" style="background: linear-gradient(135deg, var(--accent-green) 0%, var(--accent-cyan) 100%); color: white;">
                            <h5 class="mb-0"><i class="fas fa-flask"></i> Weather-Based Medicine Recommendations</h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <!-- Brinjal Medicine -->
                                <div class="col-md-6">
                                    <div class="card border-left" style="border-left: 4px solid var(--accent-green);">
                                        <div class="card-body">
                                            <h6 class="card-title mb-3">
                                                <i class="fas fa-leaf" style="color: var(--accent-green);"></i> Brinjal (बैंगन)
                                            </h6>
                                            <div id="brinjalMedicine" class="small">
                                                <!-- Medicine details will be populated here -->
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Grapes Medicine -->
                                <div class="col-md-6">
                                    <div class="card border-left" style="border-left: 4px solid #8b5cf6;">
                                        <div class="card-body">
                                            <h6 class="card-title mb-3">
                                                <i class="fas fa-wine-glass" style="color: #8b5cf6;"></i> Grapes (अंगूर)
                                            </h6>
                                            <div id="grapesMedicine" class="small">
                                                <!-- Medicine details will be populated here -->
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- FORECAST -->
            <div class="row mt-4">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="fas fa-calendar"></i> 5-Day Forecast</h5>
                        </div>
                        <div class="card-body">
                            <div id="forecastContainer" class="row g-3">
                                <!-- Forecast cards will be populated here -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- FOOTER -->
    <footer>
        <div class="container">
            <div class="row g-4 mb-4">
                <div class="col-md-3">
                    <h5><i class="fas fa-leaf" style="color: var(--accent-green);"></i> DualCrop</h5>
                    <p class="small text-muted">AI-powered crop disease detection for modern farmers.</p>
                </div>
                <div class="col-md-3">
                    <h5>Quick Links</h5>
                    <ul class="list-unstyled small">
                        <li><a href="/">Home</a></li>
                        <li><a href="/analyze">Analyze</a></li>
                        <li><a href="/dashboard">Dashboard</a></li>
                        <li><a href="/about">About</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h5>Features</h5>
                    <ul class="list-unstyled small">
                        <li><a href="/analyze">Disease Detection</a></li>
                        <li><a href="/weather">Weather Advisory</a></li>
                        <li><a href="/chatbot">AI Chatbot</a></li>
                        <li><a href="/dashboard">Analytics</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h5>Follow</h5>
                    <div class="social-links">
                        <a href="#" title="Facebook"><i class="fab fa-facebook"></i></a>
                        <a href="#" title="Twitter"><i class="fab fa-twitter"></i></a>
                        <a href="#" title="LinkedIn"><i class="fab fa-linkedin"></i></a>
                        <a href="#" title="GitHub"><i class="fab fa-github"></i></a>
                    </div>
                </div>
            </div>
            <div class="footer-divider"></div>
            <div class="text-center">
                <p class="footer-text mb-0">
                    <strong>DualCrop Smart Advisory System</strong> © 2024. All rights reserved. | Built with <i class="fas fa-heart" style="color: #ec4899;"></i> for Modern Agriculture
                </p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/language-manager.js"></script>
    <script src="/js/main.js"></script>
    <script>
        document.getElementById('weatherForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const city = document.getElementById('cityInput').value;
            
            document.getElementById('weatherLoading').style.display = 'block';
            document.getElementById('weatherDisplay').style.display = 'none';

            try {
                const response = await fetch(`/api/weather`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ city: city })
                });
                const data = await response.json();

                if (data.success) {
                    displayWeather(data);
                    document.getElementById('weatherDisplay').style.display = 'block';
                } else {
                    alert(data.error || 'Could not fetch weather data');
                }
            } catch (error) {
                alert('Error: ' + error.message);
            } finally {
                document.getElementById('weatherLoading').style.display = 'none';
            }
        });

        function displayWeather(data) {
            document.getElementById('weatherCity').textContent = data.city + ', ' + data.country;
            document.getElementById('weatherTemp').textContent = Math.round(data.temperature) + '°C';
            document.getElementById('weatherDescription').textContent = data.description;
            document.getElementById('humidity').textContent = data.humidity + '%';
            document.getElementById('windSpeed').textContent = data.windSpeed + ' m/s';
            
            // Display advisory
            if (Array.isArray(data.advisory)) {
                document.getElementById('weatherAdvisory').innerHTML = data.advisory.join('<br>');
            } else {
                document.getElementById('weatherAdvisory').textContent = data.advisory || 'Monitor weather conditions and adjust farming practices accordingly.';
            }

            const icons = {
                'Clear': 'fas fa-sun',
                'Clouds': 'fas fa-cloud',
                'Rain': 'fas fa-cloud-rain',
                'Snow': 'fas fa-snowflake',
                'Thunderstorm': 'fas fa-bolt'
            };
            const iconClass = icons[data.condition] || 'fas fa-cloud';
            document.getElementById('weatherIcon').className = iconClass;

            // Display medicine recommendations
            if (data.cropMedicines && (data.cropMedicines.Brinjal || data.cropMedicines.Grapes)) {
                displayMedicineRecommendations(data.cropMedicines);
                document.getElementById('medicineSection').style.display = 'block';
            }
        }

        function displayMedicineRecommendations(cropMedicines) {
            const brinjalMedicineDiv = document.getElementById('brinjalMedicine');
            const grapesMedicineDiv = document.getElementById('grapesMedicine');

            // Display Brinjal medicine
            if (cropMedicines.Brinjal) {
                const brinjal = cropMedicines.Brinjal;
                let brinjalHTML = '';

                if (brinjal.description) {
                    brinjalHTML += `<p class="mb-2"><strong>${brinjal.description}</strong></p>`;
                }

                if (Array.isArray(brinjal.medicine)) {
                    brinjalHTML += `<p class="mb-2"><strong>Medicines:</strong><br>${brinjal.medicine.join(', ')}</p>`;
                } else if (brinjal.medicine) {
                    brinjalHTML += `<p class="mb-2"><strong>Medicine:</strong> ${brinjal.medicine}</p>`;
                }

                if (brinjal.dosage) {
                    brinjalHTML += `<p class="mb-2"><strong>Dosage:</strong> ${brinjal.dosage}</p>`;
                }

                if (brinjal.spraying_interval) {
                    brinjalHTML += `<p class="mb-2"><strong>Interval:</strong> ${brinjal.spraying_interval}</p>`;
                }

                if (brinjal.preventive && Array.isArray(brinjal.preventive)) {
                    brinjalHTML += '<p class="mb-2"><strong>Preventive Measures:</strong><ul class="mb-0" style="padding-left: 20px;">';
                    brinjal.preventive.forEach(item => {
                        brinjalHTML += `<li>${item}</li>`;
                    });
                    brinjalHTML += '</ul></p>';
                }

                brinjalMedicineDiv.innerHTML = brinjalHTML;
            } else {
                brinjalMedicineDiv.innerHTML = '<p class="text-secondary">No specific recommendation for current conditions</p>';
            }

            // Display Grapes medicine
            if (cropMedicines.Grapes) {
                const grapes = cropMedicines.Grapes;
                let grapesHTML = '';

                if (grapes.description) {
                    grapesHTML += `<p class="mb-2"><strong>${grapes.description}</strong></p>`;
                }

                if (Array.isArray(grapes.medicine)) {
                    grapesHTML += `<p class="mb-2"><strong>Medicines:</strong><br>${grapes.medicine.join(', ')}</p>`;
                } else if (grapes.medicine) {
                    grapesHTML += `<p class="mb-2"><strong>Medicine:</strong> ${grapes.medicine}</p>`;
                }

                if (grapes.dosage) {
                    grapesHTML += `<p class="mb-2"><strong>Dosage:</strong> ${grapes.dosage}</p>`;
                }

                if (grapes.spraying_interval) {
                    grapesHTML += `<p class="mb-2"><strong>Interval:</strong> ${grapes.spraying_interval}</p>`;
                }

                if (grapes.preventive && Array.isArray(grapes.preventive)) {
                    grapesHTML += '<p class="mb-2"><strong>Preventive Measures:</strong><ul class="mb-0" style="padding-left: 20px;">';
                    grapes.preventive.forEach(item => {
                        grapesHTML += `<li>${item}</li>`;
                    });
                    grapesHTML += '</ul></p>';
                }

                grapesHTML += '<p class="text-muted mt-3"><small>💡 Adjust application frequency based on rainfall and climate conditions</small></p>';

                grapesMedicineDiv.innerHTML = grapesHTML;
            } else {
                grapesMedicineDiv.innerHTML = '<p class="text-secondary">No specific recommendation for current conditions</p>';
            }
        }



        function changeLanguage(lang) {
            if (languageManager) {
                languageManager.setLanguage(lang);
                languageManager.applyTranslations();
            }
        }
    </script>
</body>
</html>
