    <!-- MAIN CONTENT -->
    <main class="flex-grow-1 section-padding">
        <div class="container">
            <div class="text-center mb-5">
                <h1 class="gradient-text mb-3">🔬 AI Disease Detection</h1>
                <p class="text-secondary fs-5">Upload a crop leaf image and let our AI analyze it instantly</p>
            </div>

            <div class="row g-4">
                <!-- UPLOAD SECTION -->
                <div class="col-lg-6">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title mb-4">
                                <i class="fas fa-cloud-upload-alt"></i> Upload Leaf Image
                            </h5>

                            <form id="uploadForm" enctype="multipart/form-data">
                                <!-- Drag & Drop Area -->
                                <div class="upload-area" id="dropArea" ondrop="handleDrop(event)" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)">
                                    <i class="fas fa-cloud-upload-alt"></i>
                                    <p class="mt-3 mb-2"><strong>Drag & drop your image here</strong></p>
                                    <p class="text-secondary mb-3">or click to browse</p>
                                    <input type="file" id="imageInput" class="form-control" name="image" accept="image/*" hidden required />
                                </div>

                                <!-- File Info -->
                                <div class="text-center mt-2">
                                    <small class="text-secondary">
                                        <i class="fas fa-info-circle"></i> Supported: JPEG, PNG, GIF | Max: 5MB
                                    </small>
                                </div>

                                <!-- Image Preview -->
                                <div id="imagePreview" style="display: none;" class="mt-4">
                                    <p class="text-secondary mb-2">Preview:</p>
                                    <img id="previewImg" src="" alt="Preview" class="img-fluid rounded" style="max-height: 300px; width: 100%; object-fit: cover;" />
                                    <button type="button" class="btn btn-sm btn-outline-danger mt-2" onclick="clearImage()">
                                        <i class="fas fa-trash"></i> Clear
                                    </button>
                                </div>

                                <!-- Analyze Button -->
                                <button type="submit" class="btn btn-primary btn-lg w-100 mt-4" id="submitBtn">
                                    <i class="fas fa-search"></i> Analyze Image
                                </button>
                            </form>

                            <!-- Loading State -->
                            <div id="loadingState" style="display: none;" class="text-center mt-4">
                                <div class="spinner-border text-success mb-3" role="status"></div>
                                <p class="text-secondary">Analyzing your image with AI...</p>
                                <small class="text-muted">This usually takes a few seconds</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- RESULTS SECTION -->
                <div class="col-lg-6">
                    <!-- Image Gallery -->
                    <div id="imageGallery" style="display: none;">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title mb-4">
                                    <i class="fas fa-images"></i> Uploaded Images
                                </h5>
                                <div id="galleryContainer" class="row g-3">
                                    <!-- Images will be added here -->
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Success Results -->
                    <div id="resultCard" style="display: none;">
                        <!-- Disease Card -->
                        <div class="card mb-4">
                            <div class="card-body">
                                <div class="d-flex align-items-start justify-content-between mb-3">
                                    <div>
                                        <p class="text-secondary small mb-1">Disease/Crop Detected</p>
                                        <h3 id="resultDisease" class="gradient-text"></h3>
                                    </div>
                                    <i class="fas fa-check-circle" style="font-size: 2rem; color: var(--accent-green);"></i>
                                </div>
                            </div>
                        </div>

                        <!-- Confidence Score -->
                        <div class="card mb-4">
                            <div class="card-body">
                                <p class="text-secondary small mb-3">Confidence Score</p>
                                <div class="progress" style="height: 8px;">
                                    <div id="confidenceBar" class="progress-bar" role="progressbar" style="width: 0%"></div>
                                </div>
                                <div class="d-flex justify-content-between mt-2">
                                    <span id="confidenceText" class="fw-bold">0%</span>
                                    <small class="text-secondary">Accuracy</small>
                                </div>
                            </div>
                        </div>

                        <!-- Advisory Section -->
                        <div class="card mb-4" style="background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(6, 182, 212, 0.1) 100%);">
                            <div class="card-body">
                                <h6 class="card-title mb-3">
                                    <i class="fas fa-leaf" style="color: var(--accent-green);"></i> Recommendation
                                </h6>
                                <p id="advisoryText" class="mb-0"></p>
                            </div>
                        </div>

                        <!-- Medicine Recommendation -->
                        <div id="medicineBox" class="card mb-4" style="background: linear-gradient(135deg, rgba(168, 85, 247, 0.1) 0%, rgba(6, 182, 212, 0.1) 100%); display: none;">
                            <div class="card-body">
                                <h6 class="card-title mb-3">
                                    <i class="fas fa-pills" style="color: var(--accent-purple);"></i> Treatment Guide
                                </h6>
                                <div id="medicineContent"></div>
                            </div>
                        </div>

                        <!-- Flask Status -->
                        <div id="flaskStatusBadge" class="mb-4" style="display: none;">
                            <p class="small text-secondary mb-2">Analysis Method</p>
                            <span id="flaskStatusText" class="badge"></span>
                        </div>

                        <!-- Result Image -->
                        <div class="card mb-4">
                            <div class="card-body">
                                <p class="small text-secondary mb-2">Analyzed Image</p>
                                <img id="resultImage" src="" alt="Analysis" class="img-fluid rounded" style="max-height: 250px; width: 100%; object-fit: cover;" />
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-grid gap-2 d-sm-flex">
                            <a href="/dashboard" class="btn btn-success flex-grow-1">
                                <i class="fas fa-chart-bar"></i> View Dashboard
                            </a>
                            <button type="button" class="btn btn-outline-primary flex-grow-1" onclick="resetForm()">
                                <i class="fas fa-redo-alt"></i> Analyze Another
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Info Section -->
            <div class="row mt-5">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title mb-4">
                                <i class="fas fa-lightbulb"></i> Tips for Best Results
                            </h5>
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <h6 class="text-success mb-3">✓ Do's</h6>
                                    <ul class="small">
                                        <li>Take clear, focused photos of affected leaves</li>
                                        <li>Use natural lighting when possible</li>
                                        <li>Capture the diseased area clearly</li>
                                        <li>Upload JPEG or PNG format images</li>
                                    </ul>
                                </div>
                                <div class="col-md-6">
                                    <h6 class="text-danger mb-3">✗ Don'ts</h6>
                                    <ul class="small">
                                        <li>Avoid blurry or dark images</li>
                                        <li>Don't upload images larger than 5MB</li>
                                        <li>Avoid zoomed-out full plant photos</li>
                                        <li>Don't use heavily filtered images</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

