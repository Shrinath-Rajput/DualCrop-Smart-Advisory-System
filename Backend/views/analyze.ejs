<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Analyze Crop Disease | DualCrop Smart Advisory System</title>
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
        rel="stylesheet"
    />
    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="d-flex flex-column min-vh-100">
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/">
                <i class="fas fa-leaf"></i> DualCrop Advisory
            </a>
            <button
                class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarNav"
            >
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/"><i class="fas fa-home"></i> Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/analyze"
                            ><i class="fas fa-microscope"></i> Analyze</a
                        >
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/weather"
                            ><i class="fas fa-cloud-sun"></i> Weather</a
                        >
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard"
                            ><i class="fas fa-chart-bar"></i> Dashboard</a
                        >
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/chatbot"
                            ><i class="fas fa-comments"></i> Chatbot</a
                        >
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/about"
                            ><i class="fas fa-info-circle"></i> About</a
                        >
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <main class="flex-grow-1 py-5">
        <div class="container">
            <h1 class="mb-4 fw-bold">
                <i class="fas fa-microscope text-primary"></i> Analyze Crop Disease
            </h1>
            <p class="text-muted mb-4">
                Upload an image of a crop leaf to get an AI-powered disease detection report.
            </p>

            <div class="row g-4">
                <!-- UPLOAD SECTION -->
                <div class="col-md-6">
                    <div class="card shadow-sm border-0">
                        <div class="card-body">
                            <h5 class="card-title mb-4">
                                <i class="fas fa-upload"></i> Upload Leaf Image
                            </h5>

                            <!-- Upload Form -->
                            <form id="uploadForm" enctype="multipart/form-data">
                                <div class="mb-3">
                                    <label for="imageInput" class="form-label">
                                        Select Image (JPEG, PNG, GIF - Max 5MB)
                                    </label>
                                    <input
                                        type="file"
                                        class="form-control form-control-lg"
                                        id="imageInput"
                                        name="image"
                                        accept="image/*"
                                        required
                                    />
                                    <small class="text-muted"
                                        >Supported formats: JPEG, PNG, GIF</small
                                    >
                                </div>

                                <!-- Image Preview -->
                                <div id="imagePreview" class="mb-3 text-center" style="display: none">
                                    <img
                                        id="previewImg"
                                        src=""
                                        alt="Preview"
                                        class="img-fluid"
                                        style="max-height: 250px"
                                    />
                                </div>

                                <button
                                    type="submit"
                                    class="btn btn-primary btn-lg w-100"
                                    id="submitBtn"
                                >
                                    <i class="fas fa-search"></i> Analyze Image
                                </button>
                            </form>

                            <!-- Loading Spinner -->
                            <div id="loadingSpinner" style="display: none" class="text-center mt-4">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Analyzing...</span>
                                </div>
                                <p class="mt-2 text-muted">Analyzing your image...</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- RESULT SECTION -->
                <div class="col-md-6">
                    <div
                        id="resultCard"
                        class="card shadow-sm border-0"
                        style="display: none"
                    >
                        <div class="card-body">
                            <h5 class="card-title mb-4">
                                <i class="fas fa-check-circle text-success"></i> Analysis Result
                            </h5>

                            <!-- Disease Result -->
                            <div class="mb-4">
                                <label class="text-muted">Disease/Crop Detected:</label>
                                <h3 id="resultDisease" class="text-success fw-bold"></h3>
                            </div>

                            <!-- Confidence Score -->
                            <div class="mb-4">
                                <label class="text-muted">Confidence Score:</label>
                                <div class="progress" style="height: 25px">
                                    <div
                                        id="confidenceBar"
                                        class="progress-bar bg-success"
                                        role="progressbar"
                                        aria-valuenow="0"
                                        aria-valuemin="0"
                                        aria-valuemax="100"
                                    >
                                        <span id="confidenceText">0%</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Uploaded Image -->
                            <div class="mb-4">
                                <label class="text-muted">Uploaded Image:</label>
                                <img
                                    id="resultImage"
                                    src=""
                                    alt="Result"
                                    class="img-fluid rounded"
                                    style="max-height: 200px"
                                />
                            </div>

                            <!-- Advisory -->
                            <div class="alert alert-info" id="advisoryBox" role="alert">
                                <h6 class="alert-heading">
                                    <i class="fas fa-lightbulb"></i> Advisory
                                </h6>
                                <p id="advisoryText" class="mb-0"></p>
                            </div>

                            <!-- Medicine Recommendation -->
                            <div class="alert alert-warning" id="medicineBox" role="alert" style="display: none">
                                <h6 class="alert-heading">
                                    <i class="fas fa-pills"></i> 💊 Medicine Recommendation
                                </h6>
                                <div id="medicineContent"></div>
                            </div>

                            <!-- Action Buttons -->
                            <div class="d-grid gap-2 d-sm-flex">
                                <button
                                    class="btn btn-success me-sm-2"
                                    onclick="location.href='/dashboard'"
                                >
                                    <i class="fas fa-chart-bar"></i> View Dashboard
                                </button>
                                <button
                                    class="btn btn-outline-primary"
                                    onclick="resetForm()"
                                >
                                    <i class="fas fa-redo"></i> Analyze Another
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Error Message -->
                    <div id="errorAlert" class="alert alert-danger" style="display: none" role="alert">
                        <h4 class="alert-heading">
                            <i class="fas fa-exclamation-circle"></i> Error
                        </h4>
                        <p id="errorMessage"></p>
                    </div>
                </div>
            </div>

            <!-- INFO SECTION -->
            <div class="row mt-5">
                <div class="col-md-12">
                    <div class="card bg-light border-0">
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="fas fa-info-circle"></i> How to Use
                            </h5>
                            <ul>
                                <li>Take a clear photo of an affected leaf</li>
                                <li>Ensure good lighting and focus on the disease symptoms</li>
                                <li>Upload the image in JPEG, PNG, or GIF format</li>
                                <li>Wait for the AI model to analyze and provide results</li>
                                <li>
                                    View detailed advisory and recommendations for treatment
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- FOOTER -->
    <footer class="bg-dark text-white text-center py-4 mt-5 shadow">
        <div class="container">
            <p class="mb-2">
                <strong>DualCrop Smart Advisory System</strong> - AI-Based Crop Disease
                Detection
            </p>
            <p class="mb-0">
                <small>
                    Built with <i class="fas fa-heart text-danger"></i> using Node.js, Python
                    Flask, and Machine Learning
                </small>
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Image Preview
        document.getElementById("imageInput").addEventListener("change", function (e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function (event) {
                    document.getElementById("previewImg").src = event.target.result;
                    document.getElementById("imagePreview").style.display = "block";
                };
                reader.readAsDataURL(file);
            }
        });

        // Form Submission
        document.getElementById("uploadForm").addEventListener("submit", async function (e) {
            e.preventDefault();

            const formData = new FormData();
            const imageFile = document.getElementById("imageInput").files[0];

            if (!imageFile) {
                showError("Please select an image");
                return;
            }

            formData.append("image", imageFile);

            // Show loading spinner
            document.getElementById("loadingSpinner").style.display = "block";
            document.getElementById("resultCard").style.display = "none";
            document.getElementById("errorAlert").style.display = "none";

            try {
                const response = await fetch("/analyze", {
                    method: "POST",
                    body: formData,
                });

                const data = await response.json();

                if (data.success) {
                    // Show result
                    document.getElementById("resultDisease").textContent = data.prediction;
                    document.getElementById("confidenceBar").style.width = data.confidence + "%";
                    document.getElementById("confidenceBar").setAttribute("aria-valuenow", data.confidence);
                    document.getElementById("confidenceText").textContent = Math.round(data.confidence) + "%";
                    document.getElementById("resultImage").src = "/uploads/" + data.image;

                    // Generate advisory based on prediction
                    const advisory = generateAdvisory(data.prediction);
                    document.getElementById("advisoryText").textContent = advisory;

                    // Display medicine recommendation
                    if (data.medicine) {
                        displayMedicineRecommendation(data.medicine, data.prediction);
                    }

                    document.getElementById("resultCard").style.display = "block";
                } else {
                    showError(data.error || "Analysis failed");
                }
            } catch (error) {
                showError("Error: " + error.message);
            } finally {
                document.getElementById("loadingSpinner").style.display = "none";
            }
        });

        // Helper function to show error
        function showError(message) {
            document.getElementById("errorMessage").textContent = message;
            document.getElementById("errorAlert").style.display = "block";
        }

        // Helper function to reset form
        function resetForm() {
            document.getElementById("uploadForm").reset();
            document.getElementById("imagePreview").style.display = "none";
            document.getElementById("resultCard").style.display = "none";
            document.getElementById("errorAlert").style.display = "none";
        }

        // Display medicine recommendation
        function displayMedicineRecommendation(medicine, disease) {
            const medicineBox = document.getElementById("medicineBox");
            const medicineContent = document.getElementById("medicineContent");
            
            let html = "";
            
            if (medicine.description) {
                html += `<p class="fw-bold">${medicine.description}</p>`;
            }
            
            if (Array.isArray(medicine.medicine)) {
                html += `<p><strong>Medicines:</strong> ${medicine.medicine.join(", ")}</p>`;
            } else if (medicine.medicine) {
                html += `<p><strong>Medicine:</strong> ${medicine.medicine}</p>`;
            }
            
            if (medicine.dosage) {
                html += `<p><strong>Dosage:</strong> ${medicine.dosage}</p>`;
            }
            
            if (medicine.spraying_interval) {
                html += `<p><strong>Spraying Interval:</strong> Every ${medicine.spraying_interval}</p>`;
            }
            
            if (medicine.preventive && Array.isArray(medicine.preventive)) {
                html += `<p><strong>Preventive Measures:</strong></p><ul>`;
                medicine.preventive.forEach(item => {
                    html += `<li>${item}</li>`;
                });
                html += `</ul>`;
            }
            
            if (medicine.instructions && Array.isArray(medicine.instructions)) {
                html += `<p><strong>Instructions:</strong></p><ol>`;
                medicine.instructions.forEach(item => {
                    html += `<li>${item}</li>`;
                });
                html += `</ol>`;
            }
            
            medicineContent.innerHTML = html;
            medicineBox.style.display = "block";
        }

        // Helper function to reset form

        // Generate advisory based on disease
        function generateAdvisory(disease) {
            const advisories = {
                "healthy": "Your crop looks healthy! Continue regular maintenance and monitoring.",
                "blight": "Leaf blight detected. Apply fungicides immediately and improve air circulation.",
                "mildew": "Powdery mildew detected. Use sulfur-based fungicides and reduce humidity.",
                "rust": "Rust disease detected. Remove affected leaves and apply copper-based fungicides.",
                "rot": "Rot detected. Ensure proper drainage and reduce watering frequency.",
                "yellowing": "Yellowing observed. Check for nutrient deficiency or pest damage.",
                "spot": "Leaf spot detected. Remove infected leaves and apply appropriate fungicides.",
            };

            for (const key in advisories) {
                if (disease.toLowerCase().includes(key)) {
                    return advisories[key];
                }
            }

            return "Please consult with a local agricultural expert for detailed recommendations on: " + disease;
        }
    </script>
</body>
</html>
