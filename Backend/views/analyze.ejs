    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/language-manager.js"></script>
    <script src="/js/main.js"></script>
    <script>
        const dropArea = document.getElementById('dropArea');
        const fileInput = document.getElementById('imageInput');

        // Define all functions FIRST
        function handleDragOver(e) {
            e.preventDefault();
            e.stopPropagation();
            dropArea.classList.add('dragover');
        }

        function handleDragLeave(e) {
            e.preventDefault();
            e.stopPropagation();
            dropArea.classList.remove('dragover');
        }

        function handleDrop(e) {
            e.preventDefault();
            e.stopPropagation();
            dropArea.classList.remove('dragover');
            
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                fileInput.files = files;
                handleFileSelect();
            }
        }

        function handleFileSelect() {
            const file = fileInput.files[0];
            if (file && file.type.startsWith('image/')) {
                const reader = new FileReader();
                reader.onload = (e) => {
                    document.getElementById('previewImg').src = e.target.result;
                    document.getElementById('imagePreview').style.display = 'block';
                    addImageToGallery(e.target.result, file.name);
                };
                reader.readAsDataURL(file);
            }
        }

        function addImageToGallery(imageData, fileName) {
            const gallery = document.getElementById('imageGallery');
            const container = document.getElementById('galleryContainer');
            
            const galleryItem = document.createElement('div');
            galleryItem.className = 'col-md-6 col-lg-4';
            galleryItem.innerHTML = `
                <div class="card h-100">
                    <img src="${imageData}" class="card-img-top" alt="${fileName}" style="height: 200px; object-fit: cover;">
                    <div class="card-body">
                        <p class="card-text text-secondary small">${fileName}</p>
                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeFromGallery(this)">
                            <i class="fas fa-trash"></i> Remove
                        </button>
                    </div>
                </div>
            `;
            
            container.appendChild(galleryItem);
            gallery.style.display = 'block';
        }

        function removeFromGallery(button) {
            button.closest('.col-md-6').remove();
            const container = document.getElementById('galleryContainer');
            if (container.children.length === 0) {
                document.getElementById('imageGallery').style.display = 'none';
            }
        }

        function clearImage() {
            fileInput.value = '';
            document.getElementById('imagePreview').style.display = 'none';
        }

        function resetForm() {
            document.getElementById('uploadForm').reset();
            document.getElementById('imagePreview').style.display = 'none';
            document.getElementById('resultCard').style.display = 'none';
            document.getElementById('imageGallery').style.display = 'none';
            document.getElementById('galleryContainer').innerHTML = '';
        }

        function generateAdvisory(prediction, language = 'en') {
            const advisories = {
                'en': {
                    'healthy': 'Your crop appears healthy! Continue regular monitoring and maintain good agricultural practices.',
                    'disease': 'A disease has been detected. Follow the treatment guide below and consult a local agricultural expert if needed.'
                },
                'hi': {
                    'healthy': 'आपकी फसल स्वस्थ दिखाई देती है! नियमित निगरानी जारी रखें और अच्छी कृषि प्रथाओं को बनाए रखें।',
                    'disease': 'एक बीमारी का पता चला है। नीचे दिए गए उपचार गाइड का पालन करें और आवश्यकता पड़ने पर स्थानीय कृषि विशेषज्ञ से परामर्श लें।'
                },
                'mr': {
                    'healthy': 'आपली पिक निरोगी दिसते आहे! नियमित निरीक्षण सुरू ठेवा आणि चांगल्या कृषी पद्धतीचे पालन करा।',
                    'disease': 'एक रोग आढळला आहे। खाली दिलेल्या उपचार मार्गदर्शकाचे पालन करा आणि आवश्यकतेनुसार स्थानिक कृषी तज्ञांचा सल्ला घ्या।'
                }
            };
            
            const isHealthy = prediction.toLowerCase().includes('healthy');
            const key = isHealthy ? 'healthy' : 'disease';
            return advisories[language]?.[key] || advisories['en'][key];
        }

        // Translation mapping for disease names
        const diseaseTranslations = {
            'Brinjal Healthy Leaf': {
                'en': 'Brinjal Healthy Leaf',
                'hi': 'बैंगन स्वस्थ पत्र',
                'mr': 'वारी निरोगी पत्र'
            },
            'Grapes Healthy': {
                'en': 'Grapes Healthy',
                'hi': 'अंगूर स्वस्थ',
                'mr': 'द्राक्षे निरोगी'
            },
            'Grapes Black Rot': {
                'en': 'Grapes Black Rot',
                'hi': 'अंगूर काला सड़',
                'mr': 'द्राक्षे काळा सड'
            },
            'Grapes Esca (Black Measles)': {
                'en': 'Grapes Esca (Black Measles)',
                'hi': 'अंगूर एस्का (काले धब्बे)',
                'mr': 'द्राक्षे एस्का (काले धब्बे)'
            },
            'Grapes Leaf Blight': {
                'en': 'Grapes Leaf Blight',
                'hi': 'अंगूर पत्ती झुलसा',
                'mr': 'द्राक्षे पत्र झुलसा'
            },
            'Unknown': {
                'en': 'Unknown',
                'hi': 'अज्ञात',
                'mr': 'अज्ञात'
            }
        };

        function translateDisease(prediction, language = 'en') {
            return diseaseTranslations[prediction]?.[language] || prediction;
        }

        function displayMedicineRecommendation(medicine) {
            const box = document.getElementById('medicineBox');
            const content = document.getElementById('medicineContent');
            
            let html = '<div class="small">';
            
            if (medicine.description) {
                html += `<p class="mb-2"><strong>${medicine.description}</strong></p>`;
            }
            
            if (Array.isArray(medicine.medicine)) {
                html += `<p class="mb-2"><strong>Medicines:</strong><br>${medicine.medicine.join(', ')}</p>`;
            } else if (medicine.medicine) {
                html += `<p class="mb-2"><strong>Medicine:</strong> ${medicine.medicine}</p>`;
            }
            
            if (medicine.dosage) {
                html += `<p class="mb-2"><strong>Dosage:</strong> ${medicine.dosage}</p>`;
            }
            
            if (medicine.spraying_interval) {
                html += `<p class="mb-2"><strong>Spraying Interval:</strong> Every ${medicine.spraying_interval}</p>`;
            }
            
            if (medicine.preventive && Array.isArray(medicine.preventive)) {
                html += '<p class="mb-2"><strong>Preventive Measures:</strong><ul class="mb-0">';
                medicine.preventive.forEach(item => {
                    html += `<li>${item}</li>`;
                });
                html += '</ul></p>';
            }
            
            html += '</div>';
            content.innerHTML = html;
            box.style.display = 'block';
        }

        // Display comprehensive recommendations
        function displayComprehensiveRecommendation(rec) {
            const resultCard = document.getElementById('resultCard');
            let html = '';

            if (!rec) return;

            // Severity badge
            const severityColor = rec.severity === 'LOW' ? 'success' : 
                                 rec.severity === 'MEDIUM' ? 'warning' : 'danger';
            
            html += `
                <div class="card mb-4" style="border-left: 4px solid var(--accent-${rec.color});">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <h6 class="card-subtitle text-secondary">Disease Status & Severity</h6>
                                <h4>${rec.status}</h4>
                            </div>
                            <span class="badge bg-${severityColor}">${rec.severity}</span>
                        </div>
                        <p class="text-muted">${rec.summary}</p>
                        <small class="text-secondary">${rec.detailed_analysis}</small>
                    </div>
                </div>
            `;

            // Treatment section
            if (rec.treatment) {
                html += `<div class="card mb-4" style="background: linear-gradient(135deg, rgba(236, 72, 153, 0.05) 0%, rgba(168, 85, 247, 0.05) 100%);">
                    <div class="card-body">
                        <h6 class="card-title mb-3"><i class="fas fa-prescription-bottle"></i> Treatment Plan</h6>
                        <div class="small">`;

                if (rec.treatment.immediate) {
                    if (Array.isArray(rec.treatment.immediate)) {
                        html += '<p class="mb-2"><strong>🚨 Immediate Actions:</strong><ul class="mb-0">';
                        rec.treatment.immediate.forEach(item => {
                            html += `<li>${item}</li>`;
                        });
                        html += '</ul></p>';
                    } else {
                        html += `<p class="mb-2"><strong>🚨 Immediate Action:</strong> ${rec.treatment.immediate}</p>`;
                    }
                }

                if (rec.treatment.prevention && Array.isArray(rec.treatment.prevention)) {
                    html += '<p class="mb-2"><strong>🛡️ Prevention Measures:</strong><ul class="mb-0">';
                    rec.treatment.prevention.forEach(item => {
                        html += `<li>${item}</li>`;
                    });
                    html += '</ul></p>';
                }

                if (rec.treatment.chemical) {
                    html += '<p class="mb-2"><strong>💊 Chemical Treatment:</strong><ul class="mb-0">';
                    if (rec.treatment.chemical.medicine) {
                        html += `<li><strong>Medicines:</strong> ${Array.isArray(rec.treatment.chemical.medicine) ? rec.treatment.chemical.medicine.join(', ') : rec.treatment.chemical.medicine}</li>`;
                    }
                    if (rec.treatment.chemical.dosage) {
                        html += `<li><strong>Dosage:</strong> ${rec.treatment.chemical.dosage}</li>`;
                    }
                    if (rec.treatment.chemical.spraying_interval) {
                        html += `<li><strong>Interval:</strong> ${rec.treatment.chemical.spraying_interval}</li>`;
                    }
                    html += '</ul></p>';
                }

                if (rec.treatment.organic_alternatives && Array.isArray(rec.treatment.organic_alternatives)) {
                    html += '<p class="mb-2"><strong>🌿 Organic Alternatives:</strong><ul class="mb-0">';
                    rec.treatment.organic_alternatives.forEach(item => {
                        html += `<li>${item}</li>`;
                    });
                    html += '</ul></p>';
                }

                if (rec.treatment.cost_effective && Array.isArray(rec.treatment.cost_effective)) {
                    html += '<p class="mb-2"><strong>💰 Cost-Effective Solutions:</strong><ul class="mb-0">';
                    rec.treatment.cost_effective.forEach(item => {
                        html += `<li>${item}</li>`;
                    });
                    html += '</ul></p>';
                }

                html += '</div></div></div>';
            }

            // Irrigation & Fertilizer section
            if (rec.irrigation || rec.fertilizer) {
                html += `<div class="card mb-4">
                    <div class="card-body">
                        <h6 class="card-title mb-3"><i class="fas fa-water"></i> Care Instructions</h6>
                        <div class="row g-3">`;

                if (rec.irrigation) {
                    html += `<div class="col-md-6">
                        <p class="small mb-1"><strong>💧 Irrigation:</strong></p>
                        <ul class="small mb-0">
                            <li>${rec.irrigation.frequency}</li>
                            <li>${rec.irrigation.method}</li>
                            <li>${rec.irrigation.amount}</li>
                            <li>Best time: ${rec.irrigation.best_time}</li>
                        </ul>
                    </div>`;
                }

                if (rec.fertilizer) {
                    html += `<div class="col-md-6">
                        <p class="small mb-1"><strong>🌿 Fertilizer:</strong></p>
                        <ul class="small mb-0">
                            <li>Type: ${rec.fertilizer.type}</li>
                            <li>${rec.fertilizer.recommendation}</li>
                            <li>Amount: ${rec.fertilizer.amount}</li>
                            <li>Timing: ${rec.fertilizer.timing}</li>
                        </ul>
                    </div>`;
                }

                html += '</div></div></div>';
            }

            // Expected yield and timeline
            if (rec.expected_yield || rec.harvest_ready) {
                html += `<div class="card mb-4" style="background: linear-gradient(135deg, rgba(16, 185, 129, 0.05) 0%, rgba(6, 182, 212, 0.05) 100%);">
                    <div class="card-body">
                        <h6 class="card-title mb-2"><i class="fas fa-chart-line"></i> Expected Outcomes</h6>`;
                if (rec.expected_yield) {
                    html += `<p class="small mb-2">📊 <strong>Expected Yield:</strong> ${rec.expected_yield}</p>`;
                }
                if (rec.harvest_ready) {
                    html += `<p class="small mb-2">🎯 <strong>Timeline:</strong> ${rec.harvest_ready}</p>`;
                }
                if (rec.expected_recovery) {
                    html += `<p class="small mb-2">⏱️ <strong>Recovery Time:</strong> ${rec.expected_recovery}</p>`;
                }
                if (rec.cost_estimate) {
                    html += `<p class="small mb-0">💵 <strong>Treatment Cost:</strong> ${rec.cost_estimate}</p>`;
                }
                html += '</div></div>';
            }

            // Confidence info
            html += `<div class="alert alert-info small mb-0">
                <strong>Confidence Level:</strong> ${rec.confidence_level} (${rec.confidence}%) | 
                <strong>Status:</strong> Auto-generated recommendation
            </div>`;

            // Insert recommendations before the existing result card content
            const medicineBox = resultCard.querySelector('#medicineBox');
            if (medicineBox) {
                medicineBox.insertAdjacentHTML('beforebegin', html);
            }
        }

        function changeLanguage(lang) {
            if (languageManager) {
                languageManager.setLanguage(lang);
                languageManager.applyTranslations();
            }
        }

        // NOW attach event listeners AFTER functions are defined
        // Make upload area clickable
        dropArea.addEventListener('click', () => fileInput.click());
        fileInput.addEventListener('change', handleFileSelect);

        // Drag and drop events
        dropArea.addEventListener('ondrop', handleDrop);
        dropArea.addEventListener('ondragover', handleDragOver);
        dropArea.addEventListener('ondragleave', handleDragLeave);

        // Form submission
        document.getElementById('uploadForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const file = fileInput.files[0];
            if (!file) {
                alert('Please select an image first');
                return;
            }

            const formData = new FormData();
            formData.append('image', file);
            const language = languageManager ? languageManager.getCurrentLanguage() : localStorage.getItem('language') || 'en';
            formData.append('language', language);

            document.getElementById('loadingState').style.display = 'block';
            document.getElementById('resultCard').style.display = 'none';

            try {
                const response = await fetch('/analyze', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                if (data.success) {
                    // Get language and translate disease name
                    const language = languageManager ? languageManager.getCurrentLanguage() : localStorage.getItem('language') || 'en';
                    const translatedDisease = translateDisease(data.prediction, language);
                    
                    document.getElementById('resultDisease').textContent = translatedDisease;
                    document.getElementById('confidenceBar').style.width = data.confidence + '%';
                    document.getElementById('confidenceText').textContent = Math.round(data.confidence) + '%';
                    document.getElementById('resultImage').src = '/uploads/' + data.image;

                    // Flask status
                    const badge = document.getElementById('flaskStatusBadge');
                    const text = document.getElementById('flaskStatusText');
                    if (data.flaskAvailable) {
                        text.textContent = '✅ AI Model (Flask) - Live';
                        text.className = 'badge bg-success';
                    } else {
                        text.textContent = '⚠️ Fallback Mode';
                        text.className = 'badge bg-warning text-dark';
                    }
                    badge.style.display = 'block';

                    const advisory = generateAdvisory(data.prediction, language);
                    document.getElementById('advisoryText').textContent = advisory;

                    // Display comprehensive recommendation (NEW)
                    if (data.recommendation) {
                        displayComprehensiveRecommendation(data.recommendation);
                    }

                    // Display medicine recommendation
                    if (data.medicine) {
                        displayMedicineRecommendation(data.medicine, language);
                    }

                    document.getElementById('resultCard').style.display = 'block';
                } else {
                    alert(data.error || 'Analysis failed');
                }
            } catch (error) {
                alert('Error: ' + error.message);
            } finally {
                document.getElementById('loadingState').style.display = 'none';
            }
        });
    </script>
</body>
</html>