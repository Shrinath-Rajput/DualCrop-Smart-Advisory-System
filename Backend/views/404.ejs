<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Page Not Found | DualCrop Smart Advisory System</title>
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
        rel="stylesheet"
    />
    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="d-flex flex-column min-vh-100">
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/">
                <i class="fas fa-leaf"></i> DualCrop Advisory
            </a>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <main class="flex-grow-1 d-flex align-items-center justify-content-center">
        <div class="container">
            <div class="row">
                <div class="col-md-8 mx-auto text-center">
                    <div class="mb-4">
                        <i class="fas fa-exclamation-circle" style="font-size: 5rem; color: #ffc107"></i>
                    </div>
                    <h1 class="display-1 fw-bold mb-2">404</h1>
                    <h2 class="mb-4">Page Not Found</h2>
                    <p class="lead mb-4 text-muted">
                        Sorry, the page you are looking for doesn't exist. It might have been removed or the URL might be incorrect.
                    </p>

                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-body">
                            <h5 class="card-title">Lost? Let's get you back on track:</h5>
                            <p class="text-muted mb-3">
                                Use the navigation below to explore our platform
                            </p>
                            <div class="d-flex gap-2 justify-content-center flex-wrap">
                                <a href="/" class="btn btn-primary">
                                    <i class="fas fa-home"></i> Home
                                </a>
                                <a href="/analyze" class="btn btn-success">
                                    <i class="fas fa-microscope"></i> Analyze
                                </a>
                                <a href="/dashboard" class="btn btn-info">
                                    <i class="fas fa-chart-bar"></i> Dashboard
                                </a>
                                <a href="/about" class="btn btn-secondary">
                                    <i class="fas fa-info-circle"></i> About
                                </a>
                            </div>
                        </div>
                    </div>

                    <p class="text-muted mb-0">
                        If you believe this is an error, please <a href="/">contact us</a>.
                    </p>
                </div>
            </div>
        </div>
    </main>

    <!-- FOOTER -->
    <footer class="bg-dark text-white text-center py-4 mt-5 shadow">
        <div class="container">
            <p class="mb-2">
                <strong>DualCrop Smart Advisory System</strong> - AI-Based Crop Disease Detection
            </p>
            <p class="mb-0">
                <small>
                    Built with <i class="fas fa-heart text-danger"></i> using Node.js, Python Flask, and Machine Learning
                </small>
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
